ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('ViewDefinition [ReferenceView]'),'2;1');
FILE_NAME('hotswap_roundtrip.ifc','2026-07-02T00:00:00',('ifcfast tests'),('Skiplum'),'ifcfast','ifcfast-tests','');
FILE_SCHEMA(('IFC4'));
ENDSEC;
DATA;
/* GH #127: local-frame round-trip fixture. Two walls whose placements are
   deliberately NOT identity, so world-frame vertices differ loudly from the
   representation-item frame:
   - WallA (#60): direct SweptSolid body, extrusion Position offset
     (100,200,0), ObjectPlacement translated (10000,5000,2000) and rotated
     90 deg about Z (RefDirection (0,1,0)) — the classic double-placement
     trap for extract -> hotswap.
   - WallB (#80): MappedRepresentation with a CartesianTransformationOperator
     LocalOrigin (2000,0,0) — proves the local frame keeps the per-instance
     mapping composition (it is part of the Body items), while dropping only
     the ObjectPlacement (-4000,250,0). */
#1=IFCPROJECT('0LocalFrameProj0000001',$,'p',$,$,$,$,(#5),#2);
#2=IFCUNITASSIGNMENT((#3,#4));
#3=IFCSIUNIT(*,.LENGTHUNIT.,.MILLI.,.METRE.);
#4=IFCSIUNIT(*,.PLANEANGLEUNIT.,$,.RADIAN.);
#5=IFCGEOMETRICREPRESENTATIONCONTEXT($,'Model',3,1.0E-5,#6,$);
#6=IFCAXIS2PLACEMENT3D(#7,$,$);
#7=IFCCARTESIANPOINT((0.,0.,0.));
#32=IFCDIRECTION((0.,0.,1.));
/* WallA — direct extrusion, translated + rotated placement */
#60=IFCWALL('0LocalFrameWallA000001',$,'WallA',$,$,#61,#66,'tagA',.STANDARD.);
#61=IFCLOCALPLACEMENT($,#62);
#62=IFCAXIS2PLACEMENT3D(#63,#64,#65);
#63=IFCCARTESIANPOINT((10000.,5000.,2000.));
#64=IFCDIRECTION((0.,0.,1.));
#65=IFCDIRECTION((0.,1.,0.));
#66=IFCPRODUCTDEFINITIONSHAPE($,$,(#67));
#67=IFCSHAPEREPRESENTATION(#5,'Body','SweptSolid',(#68));
#68=IFCEXTRUDEDAREASOLID(#69,#71,#32,2500.);
#69=IFCRECTANGLEPROFILEDEF(.AREA.,$,#70,1000.,250.);
#70=IFCAXIS2PLACEMENT2D(#7,$);
#71=IFCAXIS2PLACEMENT3D(#72,$,$);
#72=IFCCARTESIANPOINT((100.,200.,0.));
/* WallB — mapped body with a LocalOrigin offset, translated placement */
#80=IFCWALL('0LocalFrameWallB000001',$,'WallB',$,$,#81,#84,'tagB',.STANDARD.);
#81=IFCLOCALPLACEMENT($,#82);
#82=IFCAXIS2PLACEMENT3D(#83,$,$);
#83=IFCCARTESIANPOINT((-4000.,250.,0.));
#84=IFCPRODUCTDEFINITIONSHAPE($,$,(#85));
#85=IFCSHAPEREPRESENTATION(#5,'Body','MappedRepresentation',(#86));
#86=IFCMAPPEDITEM(#90,#87);
#87=IFCCARTESIANTRANSFORMATIONOPERATOR3D($,$,#88,1.,$);
#88=IFCCARTESIANPOINT((2000.,0.,0.));
#90=IFCREPRESENTATIONMAP(#91,#92);
#91=IFCAXIS2PLACEMENT3D(#7,$,$);
#92=IFCSHAPEREPRESENTATION(#5,'Body','SweptSolid',(#93));
#93=IFCEXTRUDEDAREASOLID(#94,#91,#32,1500.);
#94=IFCRECTANGLEPROFILEDEF(.AREA.,$,#95,500.,200.);
#95=IFCAXIS2PLACEMENT2D(#7,$);
ENDSEC;
END-ISO-10303-21;
