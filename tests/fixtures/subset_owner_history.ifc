#21=IFCRELAGGREGATES('5YvctVUKr0kugbFTf53O9L',#8,$,$,#10,(#11));
#22=IFCRELAGGREGATES('6YvctVUKr0kugbFTf53O9L',#8,$,$,#11,(#12));
#30=IFCWALL('7YvctVUKr0kugbFTf53O9L',#8,'Wall-A',$,$,#16,$,'tag-A',.STANDARD.);
#40=IFCPROPERTYSET('9YvctVUKr0kugbFTf53O9L',#8,'Pset_WallCommon',$,(#41));
